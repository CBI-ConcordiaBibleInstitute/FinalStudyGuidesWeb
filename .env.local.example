# Concordia Bible Institute — environment template.
# Copy to .env.local and fill in real values to switch from the mock layer
# to live integrations. The app runs fully without these (demo mode).

# --- Supabase (Auth + Postgres) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (subscriptions + cart checkout) -------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_SUBSCRIPTION_PRICE_USD=99

# --- Resend (only used for the owner "new sale" notification) --------------
# Create the Resend account with the SAME email as NEXT_PUBLIC_ADMIN_EMAIL,
# then paste its API key. No domain verification needed while sending from
# onboarding@resend.dev to your own account email. (To email customers too,
# verify a domain in Resend and set EMAIL_FROM to an address on it.)
RESEND_API_KEY=
EMAIL_FROM=Concordia Bible Institute <onboarding@resend.dev>
# Your inbox — receives the checkout notification. MUST match your Resend login.
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# --- Storage (Cloudinary or S3 for study-guide files) ---------------------
STORAGE_BUCKET_URL=

# --- Site ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
